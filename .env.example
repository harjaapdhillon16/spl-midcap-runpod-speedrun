export url='https://YOUR_PROJECT.supabase.co'
export secret_key='YOUR_SUPABASE_SERVICE_ROLE_KEY'

# Optional overrides:
export SUPABASE_MEDIA_BUCKET='stock-call-media'
export SUPABASE_DATA_TABLE='app_records'
export RUNPOD_CONCURRENCY='16'
export RUNPOD_WORKDIR='/workspace/spl_speedrun_work'

# Optional IP rotation. Use paid/datacenter/residential proxies you control.
# Supported by httpx/yt-dlp, e.g. http://user:pass@host:port or socks5://...
# export PROXY_LIST='http://user:pass@proxy1:port,http://user:pass@proxy2:port'
# Or:
# export PROXY_FILE='/workspace/proxies.txt'
